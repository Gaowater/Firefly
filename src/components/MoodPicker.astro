---
import { Icon } from "astro-icon/components";

const moods = [
  { icon: "fa7-regular:face-grin-beam", label: "愉悦" },
  { icon: "fa7-regular:face-smile-beam", label: "悠闲" },
  { icon: "fa7-regular:face-laugh-squint", label: "期待" },
  { icon: "fa7-regular:face-laugh-beam", label: "自由" },
  { icon: "fa7-regular:face-frown", label: "悲伤" },
  { icon: "fa7-regular:face-meh-blank", label: "孤独" },
  { icon: "fa7-regular:face-grimace", label: "愤怒" },
  { icon: "fa7-regular:face-frown-open", label: "遗憾" },
  { icon: "fa7-regular:face-meh", label: "无聊" },
  { icon: "fa7-regular:face-rolling-eyes", label: "空虚" },
  { icon: "fa7-regular:face-grin-stars", label: "发癫" },
  { icon: "fa7-regular:face-smile-beam", label: "思念" },
];

const defaultIcon = "fa7-brands:gratipay";
---

<div class="mood-picker-wrapper" id="moodPicker">
  <button class="mood-btn" id="moodBtn" title="选择心情" type="button"
    onclick="
      var d=document.getElementById('moodDropdown');
      d.style.display = d.style.display==='none' ? 'block' : 'none';
      event.stopPropagation();
    "
  >
    <span class="mood-current-icon" id="moodCurrentIcon" data-icon={defaultIcon}>
      <Icon name={defaultIcon} />
    </span>
  </button>

  <div class="mood-dropdown" id="moodDropdown" style="display:none;">
    <div class="mood-grid">
      {moods.map((mood) => (
        <button class="mood-option" type="button"
          onclick={`var icon=document.getElementById('moodCurrentIcon');icon.setAttribute('data-icon','${mood.icon}');if(window.Iconify)window.Iconify.scan(icon);document.getElementById('moodDropdown').style.display='none';localStorage.setItem('mood-icon','${mood.icon}');`}
        >
          <Icon name={mood.icon} />
          <span class="mood-label">{mood.label}</span>
        </button>
      ))}
    </div>
    <button class="mood-reset" id="moodReset" type="button"
      onclick="
        var icon=document.getElementById('moodCurrentIcon');
        icon.setAttribute('data-icon','fa7-brands:gratipay');
        if(window.Iconify)window.Iconify.scan(icon);
        document.getElementById('moodDropdown').style.display='none';
        localStorage.removeItem('mood-icon');
      "
    >
      <Icon name="material-symbols:refresh" />
      <span>重置</span>
    </button>
  </div>
</div>

<style>
  .mood-picker-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }
  .mood-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    background: transparent;
    cursor: pointer;
    border-radius: 8px;
    transition: background 0.2s;
    color: var(--text-color, inherit);
    font-size: 20px;
  }
  .mood-btn:hover {
    background: var(--btn-regular-bg, rgba(128, 128, 128, 0.15));
  }
  .mood-current-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mood-dropdown {
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 8px;
    background: var(--card-bg, #fff);
    border: 1px solid var(--border-color, #e5e7eb);
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
    padding: 12px;
    z-index: 1000;
    min-width: 240px;
  }
  .mood-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
    margin-bottom: 8px;
  }
  .mood-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 8px 4px 4px;
    border: none;
    background: transparent;
    cursor: pointer;
    border-radius: 8px;
    transition: background 0.2s, transform 0.15s;
    font-size: 22px;
    color: var(--text-color, inherit);
  }
  .mood-option:hover {
    background: var(--btn-regular-bg, rgba(128, 128, 128, 0.1));
    transform: scale(1.1);
  }
  .mood-label {
    font-size: 11px;
    color: var(--text-meta, #888);
    white-space: nowrap;
  }
  .mood-reset {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 100%;
    padding: 6px 0;
    border: none;
    background: var(--btn-regular-bg, rgba(128, 128, 128, 0.08));
    cursor: pointer;
    border-radius: 8px;
    font-size: 13px;
    color: var(--text-meta, #888);
    transition: background 0.2s;
  }
  .mood-reset:hover {
    background: var(--btn-hover-bg, rgba(128, 128, 128, 0.15));
    color: var(--text-color, #333);
  }
</style>

<script>
  var saved = localStorage.getItem("mood-icon");
  if (saved) {
    var icon = document.getElementById("moodCurrentIcon");
    icon.setAttribute("data-icon", saved);
    if (window.Iconify) window.Iconify.scan(icon);
  }
  document.addEventListener("click", function(e) {
    var picker = document.getElementById("moodPicker");
    var dropdown = document.getElementById("moodDropdown");
    if (picker && !picker.contains(e.target)) {
      dropdown.style.display = "none";
    }
  });
</script>